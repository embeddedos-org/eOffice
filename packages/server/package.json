{
  "name": "@eoffice/server",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "start:cluster": "tsx src/cluster.ts",
    "start:pm2": "pm2 start ../../ecosystem.config.js --env production",
    "stop:pm2": "pm2 stop eoffice-api",
    "reload:pm2": "pm2 reload eoffice-api",
    "logs:pm2": "pm2 logs eoffice-api"
  },
  "dependencies": {
    "@eoffice/core": "workspace:*",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "imapflow": "^1.0.162",
    "mailparser": "^3.6.9",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "ws": "^8.16.0",
    "@sentry/node": "^8.40.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
