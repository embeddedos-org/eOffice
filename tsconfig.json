{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@eoffice/core": ["packages/core/src"],
      "@eoffice/ebot-client": ["packages/ebot-client/src"],
      "@eoffice/server": ["packages/server/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
