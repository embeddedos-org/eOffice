{
  "manifest_version": 3,
  "name": "eOffice Suite",
  "version": "0.1.0",
  "description": "AI-powered office suite — eDocs, eNotes, eSheets & more. Works offline.",
  "permissions": ["storage", "offscreen", "contextMenus"],
  "host_permissions": ["http://localhost:3001/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "eOffice Suite"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_page": "options.html",
  "offline_enabled": true,
  "browser_specific_settings": {
    "gecko": {
      "id": "eoffice@embeddedos.org",
      "strict_min_version": "109.0"
    }
  }
}
