{
  "name": "eoffice-office365-addin",
  "version": "1.0.0",
  "description": "eOffice Add-in for Microsoft 365 — eBot AI, eDocs, eSheets integration",
  "main": "src/taskpane/taskpane.js",
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "start": "webpack serve --mode development --open",
    "validate": "office-addin-manifest validate manifest.xml",
    "sideload": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "lint": "eslint src/**/*.js"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.83"
  },
  "devDependencies": {
    "office-addin-dev-certs": "^1.13.2",
    "office-addin-debugging": "^5.1.2",
    "office-addin-manifest": "^1.13.2",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "html-webpack-plugin": "^5.6.0",
    "copy-webpack-plugin": "^12.0.2",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
