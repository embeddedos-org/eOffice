{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(eoffice_http_requests_total[5m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "title": "Error Rate (5xx/s)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(eoffice_http_request_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        }
      }
    },
    {
      "title": "P95 Latency (ms)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(eoffice_http_request_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "process_uptime_seconds",
          "legendFormat": "seconds"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "RSS (MB)"
        },
        {
          "expr": "process_heap_used_bytes / 1024 / 1024",
          "legendFormat": "Heap Used (MB)"
        }
      ]
    },
    {
      "title": "Request Latency Distribution",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(eoffice_http_request_duration_ms_bucket[5m])",
          "legendFormat": "{{le}}ms"
        }
      ]
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "eoffice_active_connections",
          "legendFormat": "HTTP"
        },
        {
          "expr": "eoffice_ws_connections",
          "legendFormat": "WebSocket"
        }
      ]
    },
    {
      "title": "Request Rate by Status",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(eoffice_http_requests_total[5m])",
          "legendFormat": "Total"
        },
        {
          "expr": "rate(eoffice_http_request_errors_total[5m])",
          "legendFormat": "5xx"
        },
        {
          "expr": "rate(eoffice_http_request_4xx_total[5m])",
          "legendFormat": "4xx"
        }
      ]
    },
    {
      "title": "AI Provider Requests",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(eoffice_ai_requests_total[5m])",
          "legendFormat": "Requests"
        },
        {
          "expr": "rate(eoffice_ai_request_errors_total[5m])",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "title": "Database Size",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "eoffice_db_size_bytes / 1024 / 1024",
          "legendFormat": "MB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "MB"
        }
      }
    },
    {
      "title": "Documents Count",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 20
      },
      "targets": [
        {
          "expr": "eoffice_documents_total",
          "legendFormat": "docs"
        }
      ]
    },
    {
      "title": "Top Routes by Request Count",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
